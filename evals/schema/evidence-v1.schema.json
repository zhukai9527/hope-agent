{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hope-agent.dev/eval/evidence-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "commitSha",
    "dirty",
    "source",
    "appVersion",
    "tier",
    "policyId",
    "policyVersion",
    "policyMode",
    "policyDigest",
    "runnerDigest",
    "aggregateStatus",
    "startedAt",
    "completedAt",
    "durationMs",
    "suites",
    "cases",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": { "const": "eval-evidence.v1" },
    "commitSha": { "type": "string" },
    "dirty": { "type": "boolean" },
    "source": { "enum": ["local", "github_actions"] },
    "appVersion": { "type": "string" },
    "tier": { "enum": ["weekly", "release"] },
    "policyId": { "type": "string" },
    "policyVersion": { "type": "string" },
    "policyMode": { "enum": ["advisory", "enforce"] },
    "policyDigest": { "type": "string" },
    "runnerDigest": { "type": "string" },
    "aggregateStatus": { "enum": ["passed", "failed", "infra_error"] },
    "startedAt": { "type": "string" },
    "completedAt": { "type": "string" },
    "durationMs": { "type": "integer", "minimum": 0 },
    "suites": { "type": "array", "minItems": 1 },
    "cases": { "type": "array", "minItems": 1 },
    "artifacts": { "type": "array" },
    "waiver": { "type": "object" }
  }
}
