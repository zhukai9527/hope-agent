{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hope-agent.dev/eval/suite-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "capability",
    "adapter",
    "tiers",
    "runnerClass",
    "networkPolicy",
    "cases"
  ],
  "properties": {
    "schemaVersion": { "const": "eval-suite.v1" },
    "id": { "type": "string" },
    "version": { "type": "string" },
    "capability": { "type": "string" },
    "adapter": {
      "enum": [
        "coding_fixture_patch",
        "coding_gold_fixture_patch",
        "domain_trace_fixture",
        "dreaming_golden",
        "memory_retrieval_scale"
      ]
    },
    "tiers": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["weekly", "release"] }
    },
    "runnerClass": { "const": "hosted_linux" },
    "networkPolicy": { "const": "deny" },
    "shards": { "type": "integer", "minimum": 1, "maximum": 64 },
    "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 900 },
    "thresholds": { "type": "object" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 900 },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
