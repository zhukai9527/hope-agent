{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hope-agent.local/evals/eval-model-campaign-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "evidenceKind",
    "campaignId",
    "commitSha",
    "dirty",
    "source",
    "appVersion",
    "tier",
    "policyId",
    "policyVersion",
    "policyMode",
    "policyDigest",
    "runnerDigest",
    "runnerOs",
    "runnerArch",
    "aggregateStatus",
    "startedAt",
    "completedAt",
    "durationMs",
    "counts",
    "metrics",
    "models",
    "campaignBudget",
    "suites",
    "plannedTrials",
    "trialResults"
  ],
  "properties": {
    "schemaVersion": { "const": "eval-model-campaign.v1" },
    "evidenceKind": { "const": "model_campaign" },
    "campaignId": { "type": "string" },
    "commitSha": { "type": "string" },
    "dirty": { "type": "boolean" },
    "source": { "enum": ["local_app", "local_cli", "dedicated_runner", "github_actions"] },
    "appVersion": { "type": "string" },
    "tier": { "enum": ["nightly", "weekly", "release", "monthly"] },
    "policyId": { "type": "string" },
    "policyVersion": { "type": "string" },
    "policyMode": { "enum": ["advisory", "enforce"] },
    "policyDigest": { "type": "string" },
    "runnerDigest": { "type": "string" },
    "runnerOs": { "type": "string", "minLength": 1 },
    "runnerArch": { "type": "string", "minLength": 1 },
    "aggregateStatus": { "enum": ["passed", "failed", "infra_error"] },
    "startedAt": { "type": "string" },
    "completedAt": { "type": "string" },
    "durationMs": { "type": "integer", "minimum": 0 },
    "counts": { "type": "object" },
    "metrics": { "type": "object" },
    "models": { "type": "array", "minItems": 1 },
    "campaignBudget": { "type": "object" },
    "suites": { "type": "array", "minItems": 1 },
    "plannedTrials": { "type": "array", "minItems": 1 },
    "trialResults": { "type": "array", "minItems": 1 },
    "campaignBudgetViolations": { "type": "array", "items": { "type": "string" } },
    "guardrailViolations": { "type": "array", "items": { "type": "string" } },
    "regressions": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "artifacts": { "type": "array" },
    "waiver": { "type": "object" }
  }
}
