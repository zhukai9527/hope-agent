{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hope-agent.local/evals/model-campaign-trial-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "trialId",
    "campaignId",
    "planDigest",
    "commitSha",
    "appVersion",
    "suiteId",
    "suiteVersion",
    "suiteDigest",
    "caseId",
    "caseDigest",
    "trialIndex",
    "seed",
    "modelRole",
    "arm",
    "faultProfile",
    "modelDigest",
    "scenarioDigest",
    "environmentDigest",
    "verifierDigest",
    "promptDigest",
    "toolSchemaDigest",
    "attempt",
    "startedAt",
    "completedAt",
    "outcome",
    "attribution",
    "timings",
    "tokens",
    "cost",
    "tools",
    "orchestration",
    "trace"
  ],
  "properties": {
    "schemaVersion": { "const": "model-campaign-trial.v1" },
    "trialId": { "type": "string" },
    "campaignId": { "type": "string" },
    "planDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "commitSha": { "type": "string" },
    "appVersion": { "type": "string" },
    "suiteId": { "type": "string" },
    "suiteVersion": { "type": "string" },
    "suiteDigest": { "type": "string" },
    "caseId": { "type": "string" },
    "caseDigest": { "type": "string" },
    "trialIndex": { "type": "integer", "minimum": 0 },
    "seed": { "type": "integer", "minimum": 0 },
    "modelRole": { "type": "string" },
    "arm": { "type": "string" },
    "faultProfile": { "enum": ["clean", "chaos"] },
    "orchestrationProfile": { "type": "string" },
    "modelDigest": { "type": "string" },
    "scenarioDigest": { "type": "string" },
    "environmentDigest": { "type": "string" },
    "verifierDigest": { "type": "string" },
    "promptDigest": { "type": "string" },
    "toolSchemaDigest": { "type": "string" },
    "runtimeConfigDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "attempt": { "type": "integer", "minimum": 1 },
    "priorAttempts": { "type": "array", "maxItems": 1 },
    "startedAt": { "type": "string" },
    "completedAt": { "type": "string" },
    "outcome": {
      "enum": [
        "passed",
        "task_failed",
        "policy_failed",
        "budget_exhausted",
        "infra_error",
        "benchmark_defect",
        "simulator_error",
        "cancelled"
      ]
    },
    "failureClass": { "type": "string" },
    "attribution": { "enum": ["complete", "partial", "missing"] },
    "timings": { "type": "object" },
    "tokens": { "type": "object" },
    "cost": { "type": "object" },
    "tools": { "type": "object" },
    "orchestration": { "type": "object" },
    "milestones": { "type": "array" },
    "invariants": { "type": "array" },
    "judgeChecks": { "type": "array" },
    "trace": { "type": "object" },
    "traceEvents": { "type": "array", "maxItems": 4096 },
    "artifacts": { "type": "array" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "error": { "type": "string" }
  }
}
