{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hope-agent.local/evals/model-campaign-shard-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reference",
    "runnerDigest",
    "suiteId",
    "suiteDigest",
    "shardIndex",
    "shardTotal",
    "startedAt",
    "completedAt",
    "durationMs",
    "traceArtifact",
    "trials"
  ],
  "properties": {
    "schemaVersion": { "const": "model-campaign-shard.v1" },
    "reference": { "type": "string", "pattern": "^[0-9a-fA-F]{40}([0-9a-fA-F]{24})?$" },
    "runnerDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "suiteId": { "type": "string", "minLength": 1 },
    "suiteDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "shardIndex": { "type": "integer", "minimum": 1 },
    "shardTotal": { "type": "integer", "minimum": 1, "maximum": 64 },
    "startedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" },
    "durationMs": { "type": "integer", "minimum": 0 },
    "traceArtifact": { "type": "object" },
    "trials": {
      "type": "array",
      "items": { "$ref": "model-campaign-trial-v1.schema.json" }
    }
  }
}
