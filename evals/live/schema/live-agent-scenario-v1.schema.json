{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hope-agent.local/evals/live-agent-scenario-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "title",
    "capabilities",
    "subject",
    "environment",
    "task",
    "userSimulator",
    "verifiers",
    "network",
    "privacy",
    "cadence"
  ],
  "properties": {
    "schemaVersion": { "const": "live-agent-scenario.v1" },
    "id": { "type": "string" },
    "version": { "type": "string" },
    "title": { "type": "string" },
    "capabilities": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "businessDomains": { "type": "array", "items": { "type": "string" } },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entrypoint", "driver", "configProfile"],
      "properties": {
        "entrypoint": { "enum": ["server", "acp", "desktop"] },
        "driver": {
          "enum": [
            "chat_task",
            "coding_campaign",
            "domain_campaign",
            "goal_loop",
            "workflow",
            "async_jobs",
            "subagent_team",
            "mixed_e2e"
          ]
        },
        "configProfile": { "type": "string" },
        "toolSchemaPath": { "type": "string" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runnerClass"],
      "properties": {
        "runnerClass": {
          "enum": [
            "hosted_linux",
            "docker_linux",
            "dedicated_linux",
            "desktop_vm",
            "isolated_external_service"
          ]
        },
        "image": { "type": "string" },
        "assets": { "type": "array", "items": { "type": "string" } },
        "services": { "type": "array" },
        "controlledClock": { "type": "boolean" }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["promptPath", "successSummary"],
      "properties": {
        "promptPath": { "type": "string" },
        "hiddenTruthPath": { "type": "string" },
        "successSummary": { "type": "string" }
      }
    },
    "userSimulator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["scripted_fsm", "replay", "llm", "none"] },
        "scriptPath": { "type": "string" },
        "modelRole": { "type": "string" },
        "maxTurns": { "type": "integer", "minimum": 1 }
      }
    },
    "milestones": { "type": "array" },
    "faults": { "type": "array" },
    "verifiers": { "type": "array", "minItems": 1 },
    "invariants": { "type": "array" },
    "artifacts": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "budgets": { "type": "object" },
    "comparison": { "type": "object" },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy"],
      "properties": {
        "policy": { "enum": ["provider_only", "allowlist", "sandbox_local", "live_web"] },
        "allow": { "type": "array", "items": { "type": "string" } }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification"],
      "properties": {
        "classification": { "type": "string" },
        "redact": { "type": "array", "items": { "type": "string" } },
        "rawTraceRetentionDays": { "type": "integer", "minimum": 1, "maximum": 365 }
      }
    },
    "cadence": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["nightly", "weekly", "release", "monthly"] }
    }
  }
}
