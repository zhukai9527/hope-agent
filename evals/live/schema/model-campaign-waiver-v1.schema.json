{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hope-agent.local/evals/model-campaign-waiver-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "commitSha",
    "tag",
    "reason",
    "suites",
    "approvedBy",
    "approvedAt",
    "workflowRunId"
  ],
  "properties": {
    "schemaVersion": { "const": "model-campaign-waiver.v1" },
    "commitSha": { "type": "string", "pattern": "^[0-9a-fA-F]{40}([0-9a-fA-F]{24})?$" },
    "tag": { "type": "string", "minLength": 2 },
    "reason": { "type": "string", "minLength": 12, "maxLength": 2000 },
    "suites": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "cases": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "modelRoles": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "approvedBy": { "type": "string", "minLength": 1 },
    "approvedAt": { "type": "string", "format": "date-time" },
    "workflowRunId": { "type": "string", "minLength": 1 }
  }
}
