{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hope-agent.local/evals/model-campaign-policy-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "tier",
    "mode",
    "allowedAdapters",
    "allowedRunnerClasses",
    "allowedNetworkPolicies",
    "allowedExecutionModes",
    "allowedSources",
    "models",
    "suites",
    "campaignBudget"
  ],
  "properties": {
    "schemaVersion": { "const": "model-campaign-policy.v1" },
    "id": { "type": "string" },
    "version": { "type": "string" },
    "tier": { "enum": ["nightly", "weekly", "release", "monthly"] },
    "mode": { "enum": ["advisory", "enforce"] },
    "allowedAdapters": { "type": "array", "minItems": 1 },
    "allowedRunnerClasses": { "type": "array", "minItems": 1 },
    "allowedNetworkPolicies": { "type": "array", "minItems": 1 },
    "allowedExecutionModes": { "type": "array", "minItems": 1 },
    "allowedSources": { "type": "array", "minItems": 1 },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "providerId", "modelId"],
        "properties": {
          "role": { "type": "string" },
          "providerId": { "type": "string" },
          "modelId": { "type": "string" },
          "snapshot": { "type": "string" },
          "temperature": { "type": "number" },
          "reasoningEffort": { "type": "string" },
          "maxOutputTokens": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "suites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "required": { "type": "boolean" },
          "caseTags": { "type": "array", "items": { "type": "string" } },
          "repetitions": { "type": "integer", "minimum": 1, "maximum": 20 }
        }
      }
    },
    "budget": { "$ref": "#/$defs/budget" },
    "campaignBudget": { "$ref": "#/$defs/budget" },
    "allowLlmJudge": { "type": "boolean" },
    "performanceBlocking": { "type": "boolean" },
    "requireModelSnapshot": { "type": "boolean" },
    "artifactRetentionDays": { "type": "integer", "minimum": 1, "maximum": 365 },
    "maxInfraErrorRate": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "$defs": {
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxWallSeconds": { "type": "integer", "minimum": 1 },
        "maxModelCalls": { "type": "integer", "minimum": 1 },
        "maxInputTokens": { "type": "integer", "minimum": 1 },
        "maxOutputTokens": { "type": "integer", "minimum": 1 },
        "maxCostUsd": { "type": "number", "exclusiveMinimum": 0 },
        "maxToolCalls": { "type": "integer", "minimum": 1 },
        "maxAgents": { "type": "integer", "minimum": 1 },
        "maxConcurrency": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
