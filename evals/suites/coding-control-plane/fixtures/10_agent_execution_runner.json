      {
        "path": "docs/agent-runner.md",
        "text": "# Agent Runner\n\nInitial\n"
      }
    ],
    "changes": [
      {
        "path": "docs/agent-runner.md",
        "text": "# Agent Runner\n\nInitial\n\nExecution runner produced this candidate change.\n"
      }
    ]
  },
  "setup": {
    "goal": {
      "objective": "Update agent execution runner notes",
      "completionCriteria": "The docs-only change is produced by the execution runner and cheap validation is selected."
    },
    "tasks": [
      {
        "content": "Update docs/agent-runner.md with the execution runner note",
        "activeForm": "Updating docs/agent-runner.md",
        "status": "completed"
      }
    ]
  },
  "runs": {
    "execution": {
      "mode": "fixture_patch"
    },
    "review": {},
    "verification": {},
    "context": {
      "query": "agent execution runner notes",
      "limit": 12
    },
    "task": {
      "recordEvalRun": true,
      "evaluateGoal": true
    },
    "improvement": {
      "windowDays": 30
    }
  },
  "checks": {
