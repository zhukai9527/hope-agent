{
  "name": "agent_execution_runner_fixture_patch",
  "description": "Agent execution runner should produce a candidate result before review, verification, context retrieval, task scoring, and eval-run recording.",
  "task": {
    "id": "CE-DOC-002",
    "taskType": "doc_only",
    "title": "Execute task eval update",
    "source": "synthetic",
    "prompt": "Update docs/agent-runner.md with a short note that the execution runner produced the candidate change.",
    "executionMode": "doc_only",
    "expectedBehavior": [
      "Produce the candidate diff before scoring",
      "Change only docs/agent-runner.md"
    ],
    "forbiddenBehavior": [
