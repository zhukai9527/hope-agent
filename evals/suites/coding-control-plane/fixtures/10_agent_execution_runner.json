    ],
    "likelyFiles": [
      "docs/agent-runner.md"
    ],
    "expectedArtifacts": [
      "diff",
      "validation"
    ],
    "allowedValidation": [
      "git diff --check"
    ],
    "successCriteria": [
      "docs/agent-runner.md contains the execution runner note",
