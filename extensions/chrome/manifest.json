{
  "manifest_version": 3,
  "name": "Hope Agent Browser Control",
  "version": "0.1.0",
  "description": "Control Chrome with Hope Agent.",
  "key": "",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "debugger",
    "downloads",
    "nativeMessaging",
    "scripting",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Hope Agent Browser Control",
    "default_popup": "popup.html"
  }
}
